# ============================================================
# DATABASE (WAJIB) — PostgreSQL connection string
# ============================================================
#
# Gunakan SALAH SATU provider gratis berikut:
#
# 1. Neon (https://neon.tech) — REKOMENDASI — Free 512 MB
#    DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
# 2. Vercel Postgres — terintegrasi di Vercel Dashboard
#    DATABASE_URL otomatis ter-inject saat "Connect" di Vercel
#
# 3. Supabase (https://supabase.com) — Free 500 MB
#    DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
#
# Local development:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db
